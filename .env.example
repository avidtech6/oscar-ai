# Supabase Configuration
# Get these values from your Supabase project dashboard
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Development Settings
# Set to true to bypass auth in development
PUBLIC_DEV_BYPASS_AUTH=false

# Security Settings
# PIN validation attempts before lockout
PUBLIC_PIN_MAX_ATTEMPTS=3
# PIN lockout duration in minutes
PUBLIC_PIN_LOCKOUT_DURATION=15
# Session timeout in minutes (0 for no timeout)
PUBLIC_SESSION_TIMEOUT=60

# Storage Settings
# Maximum storage quota warning threshold (percentage)
PUBLIC_STORAGE_QUOTA_WARNING=80
# Auto-cleanup days for old encrypted data
PUBLIC_STORAGE_CLEANUP_DAYS=30